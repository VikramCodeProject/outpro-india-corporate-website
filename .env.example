# Outpro.India environment template
# Copy this file to .env for local backend development
# Copy the public values to .env.local for the Next.js frontend

############################################
# Backend (server.js / Render / Node.js)
############################################

# Server
PORT=5000
NODE_ENV=development

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Gmail SMTP configuration
# Generate an app password here:
# https://myaccount.google.com/apppasswords
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-16-character-app-password

# Recipient inbox for contact form submissions
# If not set, the backend will fall back to EMAIL_USER
CONTACT_RECEIVER_EMAIL=your-receiving-email@gmail.com

# Optional: send confirmation email back to the user
SEND_CONFIRMATION_EMAIL=true

############################################
# Frontend (.env.local for Next.js)
############################################

# EmailJS configuration (optional)
# Get these from: https://dashboard.emailjs.com
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxxxxxxxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxxxxxxxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=publicKey_xxxxxxxxxxxxx

# Google Analytics 4 (optional)
# Get your Measurement ID from Google Analytics admin
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Public site URL used for canonical and OG tags
NEXT_PUBLIC_SITE_URL=https://outpro.india
